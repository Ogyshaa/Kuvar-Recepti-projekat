@model Kuvar.Models.Korisnik
@{
    ViewBag.Title = "Registracija";
}

<div class="card" style="max-width:620px;margin:0 auto;">
    <h2>Registracija</h2>
    <p>Napravi nalog da dodajes, menjas i cuvas recepte.</p>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

        @Html.LabelFor(m => m.KorIme)
        @Html.TextBoxFor(m => m.KorIme)
        @Html.ValidationMessageFor(m => m.KorIme)

        @Html.LabelFor(m => m.Email)
        @Html.TextBoxFor(m => m.Email)
        @Html.ValidationMessageFor(m => m.Email)

        @Html.LabelFor(m => m.DatumRodjenja)
        @Html.TextBoxFor(m => m.DatumRodjenja, "{0:yyyy-MM-dd}", new { type = "date" })
        @Html.ValidationMessageFor(m => m.DatumRodjenja)

        @Html.LabelFor(m => m.Lozinka)
        @Html.PasswordFor(m => m.Lozinka)
        @Html.ValidationMessageFor(m => m.Lozinka)

        <div style="margin-top:18px;">
            <button class="btn btn-secondary" type="submit">Registracija</button>
        </div>
    }
</div>
